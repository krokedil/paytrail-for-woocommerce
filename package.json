{
    "name": "paytrail-for-woocommerce",
    "version": "2.7.0",
    "description": "Paytrail is a payment gateway that offers 20+ payment methods for Finnish customers.",
    "private": true,
    "dependencies": {
        "babel-runtime": "^6.23.0",
        "usehooks-ts": "^3.1.0"
    },
    "devDependencies": {
        "@woocommerce/dependency-extraction-webpack-plugin": "2.2.0",
        "@wordpress/scripts": "^32.3.0",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "cssnano": "^8.0.1",
        "mini-css-extract-plugin": "^2.10.2",
        "postcss-loader": "^8.2.1",
        "sass-loader": "^17.0.0"
    },
    "overrides": {
        "serialize-javascript": "^7.0.5",
        "uuid": "^11.1.1",
        "markdownlint-cli": {
            "minimatch": "^3.1.5"
        }
    },
    "scripts": {
        "start": "wp-scripts start",
        "build": "wp-scripts build",
        "build:with-i18n": "wp-scripts build && npm run i18n:build",
        "i18n": "npm run i18n:build",
        "i18n:build": "npm run i18n:pot",
        "i18n:pot": "$(which wp) i18n make-pot --exclude=\"node_modules/,languages/,assets/,vendor/\" . languages/paytrail-for-woocommerce.pot",
        "i18n:json": "$(which wp) i18n make-json languages --no-purge",
        "packages-update": "wp-scripts packages-update",
        "check-engines": "wp-scripts check-engines"
    },
    "homepage": "https://github.com/paytrail/paytrail-for-woocommerce",
    "author": "Paytrail <asiakaspalvelu@paytrail.com> (https://www.paytrail.com)",
    "license": "MIT",
    "browserslist": [
        "defaults"
    ]
}
